{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "daltogirls.com" }],
      "destination": "https://www.daltogirls.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
